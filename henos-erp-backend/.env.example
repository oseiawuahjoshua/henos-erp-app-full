# ─────────────────────────────────────────────────────────────
# Henos Energy ERP — Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it contains secrets!
# ─────────────────────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────────────────────
# This is the connection string that tells Prisma how to find
# your PostgreSQL database.
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
#
# For LOCAL development (on your own computer):
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/henos_erp"
#
# For SUPABASE (free cloud PostgreSQL — recommended for beginners):
# 1. Go to https://supabase.com → New project
# 2. Settings → Database → Connection string → URI
# Replace the line above with your Supabase URI like:
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres"

# ── SERVER ────────────────────────────────────────────────────
PORT=4000

# ── JWT SECRET ───────────────────────────────────────────────
# This is a secret key used to sign login tokens.
# Make it long and random — like a very strong password.
# You can generate one at: https://generate-secret.vercel.app/64
JWT_SECRET="change-this-to-a-long-random-string-minimum-32-characters"

# ── FRONTEND URL ─────────────────────────────────────────────
# Where your React app is running (for CORS)
FRONTEND_URL="http://localhost:5173"
